<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <ImageView
            android:id="@+id/ivUserAvatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/account_circle_24dp_000000_fill0_wght400_grad0_opsz24__1_"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="12dp"
            android:padding="10dp"/>

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ahmed"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1FA463"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Client • Alger, DZ"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginTop="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="6dp"
            android:padding="16dp"
            android:layout_marginTop="25dp"
            android:layout_marginHorizontal="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 Phone: +213 XXX XXX XXX"
                android:textColor="#333333"
                android:textSize="15sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📧 Email: user@email.com"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Déconnexion"
            android:textAllCaps="false"
            android:textColor="#D32F2F"
            android:backgroundTint="#FFE5E5"
            android:layout_marginTop="30dp"
            android:drawableStart="@drawable/login_24dp_000000_fill0_wght400_grad0_opsz24"
            android:drawablePadding="10dp"
            android:elevation="4dp"/>

    </LinearLayout>

    <include layout="@layout/bottom_menu_client"/>

</LinearLayout>