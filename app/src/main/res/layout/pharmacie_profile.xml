<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">
        <ImageView
            android:id="@+id/ivUserAvatar"
            android:layout_width="128dp"
            android:layout_height="108dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:src="@drawable/market" />

        <TextView
            android:layout_marginTop="40dp"
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pharcie Centrale"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="Status : Ouvert 24h/7j"
            android:textSize="16sp"
            android:textColor="#4CAF50"/>

        <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableStart="@drawable/login_24dp_000000_fill0_wght400_grad0_opsz24"
        android:drawablePadding="100dp"

        android:text="Déconnexion"
        android:layout_marginTop="90dp"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="#FF0000"
        android:backgroundTint="#FBD2D2"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_marginBottom="16dp" />


    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    </LinearLayout>
    <include
        android:id="@+id/bottomMenu"
        layout="@layout/button_menu_pharmacie"/>


</LinearLayout>